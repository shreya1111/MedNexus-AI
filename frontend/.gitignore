# ============================================================
# MedNexus-AI Production .gitignore
# ============================================================

############################
# Node.js
############################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################
# Next.js
############################
.next/
out/
build/
dist/

############################
# Python
############################
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

############################
# Python Virtual Environment
############################
venv/
.venv/
env/
ENV/

############################
# Environment Variables
############################
.env
.env.local
.env.development.local
.env.production.local
.env.test.local
!.env.example

############################
# IDE
############################
.vscode/
.idea/
*.swp
*.swo

############################
# Operating System
############################
.DS_Store
Thumbs.db
Desktop.ini

############################
# Logs
############################
logs/
*.log

############################
# ChromaDB & Vector Stores
############################
storage/chroma_db/
vectorstore/
faiss_index/

############################
# ML Models (Generated)
############################
models/*.pkl
models/*.joblib
models/*.onnx
models/*.pt
models/*.pth

############################
# Dataset (Generated Files)
############################
dataset/processed/

# Ignore downloaded raw documents but keep folder structure
dataset/raw/*
!dataset/raw/.gitkeep

############################
# Uploads
############################
uploads/

############################
# Cache
############################
.cache/
tmp/
temp/

############################
# Docker
############################
docker-data/

############################
# Test Reports
############################
coverage/
reports/

############################
# Build Artifacts
############################
*.tsbuildinfo

############################
# Deployment
############################
.vercel/

############################
# Secrets
############################
*.pem
*.key
*.crt

############################
# Jupyter
############################
.ipynb_checkpoints/
# Backend Service Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/mednexus
# For Docker: mongodb://admin:mednexus_secret@mongodb:27017/mednexus?authSource=admin

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-also-minimum-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis Cache (Optional - graceful degradation if unavailable)
REDIS_URL=redis://localhost:6379
# For Docker with password: redis://:redis_secret@redis:6379

# Cloudinary File Storage (Required for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# External Services
AI_SERVICE_URL=http://localhost:8000

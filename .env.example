# =============================================================================
# MedNexus-AI Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# DOCKER COMPOSE CONFIGURATION
# -----------------------------------------------------------------------------
# These are used by docker-compose.yml

# Database Passwords
MONGO_PASSWORD=mednexus_secret_change_in_production
REDIS_PASSWORD=redis_secret_change_in_production

# Grafana
GRAFANA_PASSWORD=admin

# -----------------------------------------------------------------------------
# BACKEND SERVICE
# -----------------------------------------------------------------------------

# Server
PORT=5000
NODE_ENV=production
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://admin:mednexus_secret_change_in_production@mongodb:27017/mednexus?authSource=admin

# JWT Authentication (REQUIRED - Generate secure 32+ character strings)
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis Cache (Optional - backend gracefully degrades without it)
REDIS_URL=redis://:redis_secret_change_in_production@redis:6379

# Cloudinary File Storage (Required for file upload features)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# -----------------------------------------------------------------------------
# AI SERVICES (OPTIONAL - Enables advanced AI features)
# -----------------------------------------------------------------------------

# OpenAI (for GPT-4 powered RAG)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini (alternative to OpenAI)
# GEMINI_API_KEY=your-gemini-api-key-here

# Pinecone Vector Database (for production RAG)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_INDEX=mednexus-medical
# PINECONE_ENVIRONMENT=us-east-1

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------

# API URLs (for Docker, these use internal service names)
NEXT_PUBLIC_API_URL=http://backend:5000/api/v1
NEXT_PUBLIC_AI_URL=http://ai-services:8000
NEXT_PUBLIC_WS_URL=ws://backend:5000

# For local development (when running services individually):
# NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
# NEXT_PUBLIC_AI_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:5000

# -----------------------------------------------------------------------------
# ML SERVICES
# -----------------------------------------------------------------------------

AI_SERVICE_PORT=8000

# MLflow Tracking
MLFLOW_TRACKING_URI=http://mlflow:5001

# -----------------------------------------------------------------------------
# SECURITY NOTES
# -----------------------------------------------------------------------------
# 1. Change all default passwords before production deployment
# 2. Use strong, randomly generated secrets for JWT tokens
# 3. Never commit this file with real credentials
# 4. Use environment-specific .env files (.env.production, .env.staging)
# 5. Rotate secrets regularly
# =============================================================================

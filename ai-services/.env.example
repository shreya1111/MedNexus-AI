# AI Services Environment Variables

# Server Configuration
AI_SERVICE_PORT=8000

# LLM Providers (Optional - enables full RAG capabilities)
# Uncomment and fill in when ready to enable AI features
# OPENAI_API_KEY=sk-your-openai-api-key-here
# GEMINI_API_KEY=your-google-gemini-api-key-here

# Vector Database (Optional - for production RAG)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_INDEX=mednexus-medical
# PINECONE_ENVIRONMENT=us-east-1

# MLflow Tracking (Optional)
# MLFLOW_TRACKING_URI=http://mlflow:5001
